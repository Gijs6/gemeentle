<!DOCTYPE html>
<html lang="nl">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description"
              content="Raad elke dag een Nederlandse gemeente aan de hand van hints." />
        <meta name="robots" content="index, follow" />
        <meta name="theme-color" content="#f5efe6" />

        <meta property="og:title" content="Gemeentle" />
        <meta property="og:description"
              content="Raad elke dag een Nederlandse gemeente." />
        <meta property="og:type" content="website" />
        <meta property="og:locale" content="nl_NL" />

        <title>
            {% block title %}{% endblock %}
        - Gemeentle</title>

        <meta name="htmx-config"
              content='{"responseHandling":[{"code":"204","swap":false},{"code":"[23]..","swap":true},{"code":"4..","swap":true},{"code":"5..","swap":false,"error":true}]}' />

        {% if config.DEBUG %}
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/skeleton.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/colors.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/theming.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/base.css') }}" />
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/game.css') }}" />
        {% else %}
            <link rel="stylesheet"
                  href="{{ url_for('static', filename='styles/main.min.css') }}" />
        {% endif %}

        <script src="https://kit.fontawesome.com/4a94c21782.js"
                crossorigin="anonymous"></script>
        <script src="{{ url_for('static', filename='vendor/htmx.min.js') }}" defer></script>
        <script src="{{ url_for('static', filename='js/game.js') }}" defer></script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,600;0,700;1,400&family=IBM+Plex+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap"
              rel="stylesheet" />

        {% block extra_headers %}{% endblock %}
    </head>

    <body hx-boost="true">
        {% block body_content %}{% endblock %}
    </body>
</html>
