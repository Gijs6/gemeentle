{% extends "skeleton.jinja" %}

{% block title %}{{ code }} {{ title }}{% endblock %}

{% block body_content %}
    <main class="error-page">
        <p class="error-page__code" aria-hidden="true">{{ code }}</p>
        <h1 class="error-page__title">{{ title }}</h1>
        <p class="error-page__desc">{{ description }}</p>
        <a href="{{ url_for('game.index') }}" class="btn">Terug naar home</a>
    </main>
{% endblock %}
